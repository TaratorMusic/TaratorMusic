{
	"name": "taratormusic",
	"version": "1.8.6",
	"description": "A cross-platform desktop music player application with playlists, music downloading from youtube and spotify, volume stabilisation, statistics and much more.",
	"main": "index.js",
	"bin": "index.js",
	"author": {
		"name": "Victiniiiii"
	},
	"scripts": {
		"start": "electron .",
		"build": "node compiler.js build",
		"dist": "electron-builder",
		"testdist": "npx electron-builder --dir",
		"gobuild": "node compiler.js gobuild",
		"cbuild": "node compiler.js cbuild",
		"ytdlp_fetch": "node compiler.js ytdlp_fetch"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Victiniiiii/TaratorMusic.git"
	},
	"build": {
		"publish": [
			{
				"provider": "github",
				"owner": "Victiniiiii",
				"repo": "TaratorMusic",
				"releaseType": "draft"
			}
		],
		"appId": "com.yourdomain.taratormusic",
		"productName": "TaratorMusic",
		"artifactName": "${productName}.${ext}",
		"npmRebuild": true,
		"buildDependenciesFromSource": true,
		"directories": {
			"output": "dist"
		},
		"files": [
			"**/*",
			"!musics/**",
			"!thumbnails/**",
			"!databases/**",
			"!bin/**"
		],
		"extraResources": [
			{
				"from": "bin/",
				"to": "bin",
				"filter": [
					"**/*"
				]
			},
			{
				"from": "assets/",
				"to": "assets",
				"filter": [
					"**/*"
				]
			}
		],
		"win": {
			"target": [
				"portable"
			],
			"icon": "assets/tarator_icon.ico",
			"asar": false
		},
		"mac": {
			"target": "dmg",
			"icon": "assets/tarator_icon.icns"
		},
		"linux": {
			"target": [
				"AppImage"
			],
			"icon": "assets/tarator_icon.png",
			"category": "Audio",
			"maintainer": "Victiniiiii",
			"synopsis": "A cross-platform desktop music player application with playlists, music downloading from youtube and spotify, volume stabilisation, statistics and much more.",
			"asar": false,
			"desktop": {
				"entry": {
					"Name": "TaratorMusic",
					"Comment": "A cross-platform desktop music player application with playlists, music downloading from youtube and spotify, volume stabilisation, statistics and much more.",
					"StartupWMClass": "TaratorMusic",
					"Terminal": false
				}
			}
		}
	},
	"dependencies": {
		"@distube/ytpl": "github:Victiniiiii/ytpl#1d5414f75dbc03a70dd04b92facee9362c7ed5b5",
		"@ffmpeg-installer/ffmpeg": "^1.1.0",
		"chart.js": "^4.5.0",
		"cheerio": "^1.1.0",
		"discord-rpc": "github:Victiniiiii/RPC-Listening",
		"electron-is-dev": "^3.0.1",
		"electron-updater": "^6.6.2",
		"ffprobe-static": "^3.1.0",
		"fluent-ffmpeg": "^2.1.3",
		"mpris-service": "^2.1.2",
		"puppeteer": "^24.12.1"
	},
	"devDependencies": {
		"electron": "^40.7.0",
		"electron-builder": "^26.8.1"
	}
}
